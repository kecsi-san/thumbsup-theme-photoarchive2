<!DOCTYPE html>
<html>

  <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, user-scalable=no" />
      <title>{{gallery.title}} - {{album.title}}</title>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lightgallery-bundle.min.css" integrity="sha512-nUqPe0+ak577sKSMThGcKJauRI7ENhKC2FQAOOmdyCYSrUh0GnwLsZNYqwilpMmplN+3nO3zso8CWUgu33BDag==" crossorigin="anonymous" referrerpolicy="no-referrer" />
      <link rel="stylesheet" href="{{relative 'public/core.css'}}" />
      <link rel="stylesheet" href="{{relative 'public/theme.css'}}" />

      <link rel="icon" type="image/png" href="{{relative 'public/icon.png'}}">

      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/justifiedGallery/3.8.1/css/justifiedGallery.min.css" integrity="sha512-CRFv/YVJyElHXTiMgnhWKd2f04Hd/BUJkwcyqYmlpL1ugSYW23nNRazLk960mlz7dugTrETCGGjcsnspPOS6qA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  </head>

  <body>

    {{> content}}
    {{> video-loader}}

    <!-- jquery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>


    <!-- LightGallery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/lightgallery.min.js" integrity="sha512-jEJ0OA9fwz5wUn6rVfGhAXiiCSGrjYCwtQRUwI/wRGEuWRZxrnxoeDoNc+Pnhx8qwKVHs2BRQrVR9RE6T4UHBg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/zoom/lg-zoom.min.js" integrity="sha512-BLW2Jrofiqm6m7JhkQDIh2olT0EBI58+hIL/AXWvo8gOXKmsNlU6myJyEkTy6rOAAZjn0032FRk8sl9RgXPYIQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/thumbnail/lg-thumbnail.min.js" integrity="sha512-VBbe8aA3uiK90EUKJnZ4iEs0lKXRhzaAXL8CIHWYReUwULzxkOSxlNixn41OLdX0R1KNP23/s76YPyeRhE6P+Q==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/autoplay/lg-autoplay.min.js" integrity="sha512-1YRlp9jO1ermVx9E3UzfBwoo88ODK0i9l2C2lNoZwCZAzvRdA+O0Lm00bUfkIf/A1esj4OK9yZ3yfgfa+FcYwg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script type="text/javascript">
      var gallery = document.getElementById('gallery');
      var currentMap = null;

      // Independent info panel appended directly to <body> - deliberately
      // NOT using lightGallery's data-sub-html/.lg-sub-html mechanism,
      // since that element is animated/repositioned by lightGallery's own
      // JS for its default bottom-caption-bar use case, which fights any
      // attempt to turn it into a persistent full-height sidebar.
      var infoPanel = document.createElement('div');
      infoPanel.className = 'lg-info-panel';
      infoPanel.innerHTML =
        '<div class="lg-info-header">' +
          '<h3>Image Information</h3>' +
          '<button type="button" class="lg-info-close-btn" aria-label="Close photo info">&times;</button>' +
        '</div>' +
        '<div class="lg-info-body"></div>';
      document.body.appendChild(infoPanel);
      infoPanel.querySelector('.lg-info-close-btn').addEventListener('click', function () {
        setInfoVisible(false);
      });

      function escapeHtml (str) {
        var div = document.createElement('div');
        div.textContent = str == null ? '' : str;
        return div.innerHTML;
      }

      function fieldRow (label, value) {
        if (!value) return '';
        return '<p><span class="label">' + label + ':</span> ' + escapeHtml(value) + '</p>';
      }

      // Reads the data-* attributes (already rendered server-side per
      // photo) off the original thumbnail element for the given slide
      // index, and renders them into the info panel body.
      function renderInfoPanel (index) {
        var items = gallery.querySelectorAll(':scope > a, :scope > li');
        var el = items[index];
        var body = infoPanel.querySelector('.lg-info-body');
        if (!el) { body.innerHTML = ''; return; }
        var d = el.dataset;
        var html = '';
        html += fieldRow('Filename', d.caption);
        html += fieldRow('Date Taken', d.dateTaken);
        html += fieldRow('Aperture', d.fnumber ? 'f/' + d.fnumber : '');
        html += fieldRow('Exposure', d.exposuretime ? d.exposuretime + ' sec' : '');
        html += fieldRow('ISO', d.isospeedratings);
        html += fieldRow('Focal Length', d.focallength);
        html += fieldRow('Model', d.model);
        html += fieldRow('Make', d.make);
        if (d.gpslatitude) {
          html += '<hr>';
          html += fieldRow('Latitude', d.gpslatitude + ' ' + (d.gpslatituderef || ''));
          html += fieldRow('Longitude', d.gpslongitude + ' ' + (d.gpslongituderef || ''));
          html += fieldRow('Altitude', d.gpsaltitude);
          html += '<div class="lg-map" data-lat="' + d.gpslatitude + '" data-lon="' + d.gpslongitude + '"></div>';
        }
        body.innerHTML = html;
      }

      function setInfoVisible (visible) {
        infoPanel.classList.toggle('lg-info-panel-open', visible);
        var outer = document.querySelector('.lg-outer');
        if (outer) outer.classList.toggle('lg-info-visible', visible);
        if (visible) {
          initMapIfPresent();
        }
        // The sidebar claims/releases width from the image area -
        // nudge lightGallery to recompute the image size for it.
        setTimeout(function () {
          window.dispatchEvent(new Event('resize'));
        }, 260);
      }

      // (Re)creates the Leaflet map for the currently displayed photo,
      // only while the info panel is actually visible - Leaflet can't
      // size itself correctly inside a display:none container.
      function initMapIfPresent () {
        if (!infoPanel.classList.contains('lg-info-panel-open')) return;
        if (currentMap) {
          currentMap.remove();
          currentMap = null;
        }
        var mapEl = infoPanel.querySelector('.lg-map');
        if (!mapEl) return;
        var lat = parseFloat(mapEl.getAttribute('data-lat'));
        var lon = parseFloat(mapEl.getAttribute('data-lon'));
        if (isNaN(lat) || isNaN(lon)) return;
        currentMap = L.map(mapEl).setView([lat, lon], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(currentMap);
        L.marker([lat, lon]).addTo(currentMap);
      }

      // Custom info-toggle button in the toolbar, placed right before
      // the close icon (matches: play, download, info, close)
      gallery.addEventListener('lgAfterOpen', function () {
        var toolbar = document.querySelector('.lg-toolbar');
        var closeBtn = toolbar && toolbar.querySelector('.lg-close');
        if (toolbar && !toolbar.querySelector('.lg-info-toggle-btn')) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'lg-icon lg-info-toggle-btn';
          btn.setAttribute('aria-label', 'Toggle photo info');
          btn.innerHTML = '&#9432;';
          btn.addEventListener('click', function () {
            setInfoVisible(!infoPanel.classList.contains('lg-info-panel-open'));
          });
          toolbar.insertBefore(btn, closeBtn || null);
        }
        renderInfoPanel(0);
      });

      // Hide the panel again once the lightbox itself closes
      gallery.addEventListener('lgAfterClose', function () {
        setInfoVisible(false);
      });

      // Re-render the info panel and map whenever the slide changes
      gallery.addEventListener('lgAfterSlide', function (event) {
        renderInfoPanel(event.detail.index);
        initMapIfPresent();
      });

      lightGallery(gallery, {
        speed: 400,
        loop : false,
        controls: true,
        counter: true,
        download: true,
        licenseKey: "GNU GPL license v3", // not for commercial use!

        thumbnail: true,
        toggleThumb: true,
        animateThumb: true,
        allowMediaOverlap: true,
        enableThumbDrag: true,
        thumbWidth: 75,
        thumbHeight: "50px",

        autoplay: false,
        progressBar: true,
        autoplayControls: true,

        plugins: [lgZoom, lgThumbnail, lgAutoplay]
      });
      console.log("started lightgallery")
    </script>

    <!-- Justified gallery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/justifiedGallery/3.8.1/js/jquery.justifiedGallery.min.js" integrity="sha512-8dQZtymfQeDiZ4bBCFhrKZhDcZir15MqnEDBRiR6ReIVHLcdnCyJrhPIS0QifLGuMkFZsw9QMNeD9JtiLwieTQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
      $("#gallery").justifiedGallery({
        rowHeight: 240,
        maxRowHeight: "200%",
        lastRow: 'nojustify',
        margins: 32,
        captions: true,
        border: 0,
        cssAnimation: true,

      });
      console.log("started justifiedGallery")
    </script>


  </body>
</html>